    {
      "id": "-aZxff-s654im6Z_mMHOc",
      "type": "text",
      "x": 1559.3365876036473,
      "y": 1491.4429565571756,
      "width": 1468.11572265625,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
