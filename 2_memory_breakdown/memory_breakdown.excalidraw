    {
      "id": "xbnog3hYSH5IUH6SXMXW7",
      "type": "text",
      "x": 412.69714683534835,
      "y": 1895.2232958187046,
      "width": 912.0158081054688,
      "height": 735,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2s",
      "roundness": null,
      "seed": 66705993,
      "version": 891,
      "versionNonce": 476780679,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773193702223,
      "link": null,
      "locked": false,
      "text": "1. x -> sbh\n\n2. Q -> sbh\n\n3. K -> sbh\n\n4. V -> sbh\n\n5. Q@KT (Attn scores) ->  bHs^2\n\n6. A (Attn weights) -> bHs^2\n\n7. Z -> sbh\n\nTotal -> 5 sbh + 2 bHs^2 -> X 2 (for float 16)\n\n        = 10 sbh + 4 bHs^2 + bsh (dropout) + bHs^2 (attn dropout)\n\n        = 11 sbh + 5 bHs^2\n\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. x -> sbh\n\n2. Q -> sbh\n\n3. K -> sbh\n\n4. V -> sbh\n\n5. Q@KT (Attn scores) ->  bHs^2\n\n6. A (Attn weights) -> bHs^2\n\n7. Z -> sbh\n\nTotal -> 5 sbh + 2 bHs^2 -> X 2 (for float 16)\n\n        = 10 sbh + 4 bHs^2 + bsh (dropout) + bHs^2 (attn dropout)\n\n        = 11 sbh + 5 bHs^2\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fYt9fDgu0Wx8e2iMcuC9G",
      "type": "text",
      "x": 392.60877481899524,
      "y": 619.7599777936468,
      "width": 396.1438903808594,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
